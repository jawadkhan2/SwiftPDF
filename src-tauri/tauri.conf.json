{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwiftPDF",
  "version": "1.0.3",
  "identifier": "com.swiftpdf.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SwiftPDF",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jawadkhan2/SwiftPDF/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCQkREOEM4NkIzMzhDREUKUldUZWpETnJ5Tmk5SzJ4djArNFM2VlN6L0syTUh2RSt4NlA3ZUtlVnFmOS9mTjFNYVhzMytLV3gK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
